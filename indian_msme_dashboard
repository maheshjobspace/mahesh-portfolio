<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>India MSME Intelligence Dashboard</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;600&display=swap');

  :root {
    --bg: #081120;
    --bg2: #0d1929;
    --card: #111827;
    --card2: #162033;
    --border: rgba(0,212,255,0.12);
    --primary: #00D4FF;
    --success: #00FF94;
    --accent: #7B61FF;
    --warning: #FFB547;
    --danger: #FF4D6D;
    --text: #ffffff;
    --text2: #8B9FC4;
    --text3: #4A5B7A;
    --glow: rgba(0,212,255,0.15);
    --glow2: rgba(123,97,255,0.15);
  }

  * { margin:0; padding:0; box-sizing:border-box; }
  
  html { scroll-behavior: smooth; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    line-height: 1.6;
    overflow-x: hidden;
  }

  /* SCROLLBAR */
  ::-webkit-scrollbar { width: 6px; }
  ::-webkit-scrollbar-track { background: var(--bg); }
  ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }

  /* TOP HEADER BAR */
  .topbar {
    position: fixed; top: 0; left: 0; right: 0; z-index: 1000;
    background: rgba(8,17,32,0.92);
    backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--border);
    padding: 0 24px;
    height: 56px;
    display: flex; align-items: center; justify-content: space-between;
  }
  .topbar-left { display: flex; align-items: center; gap: 16px; }
  .topbar-logo {
    font-size: 13px; font-weight: 700; letter-spacing: 2px;
    color: var(--primary); text-transform: uppercase;
  }
  .topbar-divider { width: 1px; height: 24px; background: var(--border); }
  .topbar-title { font-size: 13px; font-weight: 500; color: var(--text2); }
  .topbar-right { display: flex; align-items: center; gap: 12px; }
  /* SIDEBAR NAV */
  .sidebar {
    position: fixed; left: 0; top: 56px; bottom: 0; width: 56px;
    background: rgba(8,17,32,0.96); border-right: 1px solid var(--border);
    display: flex; flex-direction: column; align-items: center; padding: 16px 0;
    gap: 4px; z-index: 900; overflow: hidden;
    transition: width 0.3s ease;
  }
  .sidebar:hover { width: 200px; }
  .nav-item {
    width: 100%; display: flex; align-items: center; gap: 12px;
    padding: 10px 16px; cursor: pointer; border-radius: 0;
    transition: all 0.2s; color: var(--text3); white-space: nowrap;
    font-size: 12px; font-weight: 500;
  }
  .nav-item:hover, .nav-item.active { color: var(--primary); background: rgba(0,212,255,0.07); }
  .nav-item svg { flex-shrink: 0; }
  .nav-label { opacity: 0; transition: opacity 0.2s; }
  .sidebar:hover .nav-label { opacity: 1; }

  /* MAIN CONTENT */
  .main {
    margin-left: 56px;
    margin-top: 56px;
    padding: 28px 28px 60px;
  }

  /* SECTION HEADERS */
  .section { margin-bottom: 40px; }
  .section-header {
    display: flex; align-items: center; gap: 12px; margin-bottom: 20px;
  }
  .section-badge {
    font-size: 10px; font-weight: 700; letter-spacing: 1.5px;
    color: var(--primary); text-transform: uppercase;
    background: rgba(0,212,255,0.08); border: 1px solid rgba(0,212,255,0.2);
    padding: 3px 8px; border-radius: 3px;
  }
  .section-title { font-size: 18px; font-weight: 700; letter-spacing: -0.3px; }
  .section-sub { font-size: 12px; color: var(--text2); margin-top: 2px; }
  .section-line { flex: 1; height: 1px; background: var(--border); }

  /* CARDS */
  .card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 20px;
    position: relative; overflow: hidden;
    transition: border-color 0.3s, transform 0.2s;
  }
  .card:hover { border-color: rgba(0,212,255,0.3); transform: translateY(-1px); }
  .card::before {
    content: '';
    position: absolute; top: 0; left: 0; right: 0; height: 1px;
    background: linear-gradient(90deg, transparent, var(--primary), transparent);
    opacity: 0; transition: opacity 0.3s;
  }
  .card:hover::before { opacity: 1; }

  /* GRIDS */
  .grid-6 { display: grid; grid-template-columns: repeat(6,1fr); gap: 16px; }
  .grid-4 { display: grid; grid-template-columns: repeat(4,1fr); gap: 16px; }
  .grid-3 { display: grid; grid-template-columns: repeat(3,1fr); gap: 16px; }
  .grid-2 { display: grid; grid-template-columns: repeat(2,1fr); gap: 16px; }
  .grid-1-2 { display: grid; grid-template-columns: 1fr 2fr; gap: 16px; }
  .grid-2-1 { display: grid; grid-template-columns: 2fr 1fr; gap: 16px; }

  /* KPI CARDS */
  .kpi-icon {
    width: 40px; height: 40px; border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    margin-bottom: 14px; font-size: 18px;
  }
  .kpi-label { font-size: 11px; font-weight: 500; color: var(--text3); text-transform: uppercase; letter-spacing: 0.8px; margin-bottom: 6px; }
  .kpi-value { font-size: 26px; font-weight: 800; letter-spacing: -1px; font-family: 'JetBrains Mono', monospace; }
  .kpi-delta { font-size: 11px; margin-top: 6px; display: flex; align-items: center; gap: 4px; }
  .delta-up { color: var(--success); }
  .delta-down { color: var(--danger); }

  .kpi-c1 { background: rgba(0,212,255,0.08); border-color: rgba(0,212,255,0.2); }
  .kpi-c1 .kpi-icon { background: rgba(0,212,255,0.15); color: var(--primary); }
  .kpi-c1 .kpi-value { color: var(--primary); }
  .kpi-c2 { background: rgba(0,255,148,0.05); border-color: rgba(0,255,148,0.15); }
  .kpi-c2 .kpi-icon { background: rgba(0,255,148,0.12); color: var(--success); }
  .kpi-c2 .kpi-value { color: var(--success); }
  .kpi-c3 { background: rgba(123,97,255,0.07); border-color: rgba(123,97,255,0.2); }
  .kpi-c3 .kpi-icon { background: rgba(123,97,255,0.15); color: var(--accent); }
  .kpi-c3 .kpi-value { color: var(--accent); }
  .kpi-c4 { background: rgba(255,181,71,0.06); border-color: rgba(255,181,71,0.2); }
  .kpi-c4 .kpi-icon { background: rgba(255,181,71,0.15); color: var(--warning); }
  .kpi-c4 .kpi-value { color: var(--warning); }

  /* CHART CONTAINER */
  .chart-wrap { position: relative; width: 100%; }
  .chart-title {
    font-size: 13px; font-weight: 600; color: var(--text);
    margin-bottom: 4px;
  }
  .chart-sub { font-size: 11px; color: var(--text3); margin-bottom: 16px; }

  /* INDIA MAP SVG SECTION */
  .map-container {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 24px;
    display: flex; gap: 24px;
  }
  .map-svg-wrap { flex: 1; min-height: 400px; position: relative; }
  .map-legend { width: 200px; }
  .legend-title { font-size: 11px; font-weight: 700; color: var(--text2); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 12px; }
  .legend-item { display: flex; align-items: center; gap: 8px; margin-bottom: 8px; font-size: 12px; }
  .legend-dot { width: 12px; height: 12px; border-radius: 3px; flex-shrink: 0; }
  .state-rank { font-size: 11px; color: var(--text3); margin-left: auto; font-family: 'JetBrains Mono', monospace; }

  /* RANK LIST */
  .rank-list { display: flex; flex-direction: column; gap: 8px; }
  .rank-item {
    display: flex; align-items: center; gap: 10px;
    padding: 10px 12px;
    background: var(--bg2); border-radius: 8px;
    border: 1px solid transparent;
    transition: border-color 0.2s;
  }
  .rank-item:hover { border-color: var(--border); }
  .rank-num {
    width: 24px; height: 24px; border-radius: 6px;
    background: rgba(0,212,255,0.1); color: var(--primary);
    font-size: 11px; font-weight: 700; display: flex; align-items: center; justify-content: center;
    flex-shrink: 0; font-family: 'JetBrains Mono', monospace;
  }
  .rank-name { font-size: 12px; font-weight: 600; flex: 1; }
  .rank-bar-wrap { width: 100px; height: 4px; background: rgba(255,255,255,0.05); border-radius: 2px; }
  .rank-bar { height: 4px; border-radius: 2px; background: var(--primary); }
  .rank-val { font-size: 11px; color: var(--text2); font-family: 'JetBrains Mono', monospace; min-width: 48px; text-align: right; }

  /* CREDIT SECTION */
  .credit-flow {
    display: flex; align-items: center; justify-content: space-between;
    gap: 8px; flex-wrap: wrap; margin-bottom: 20px;
  }
  .credit-node {
    background: var(--bg2); border: 1px solid var(--border);
    border-radius: 10px; padding: 14px 16px; text-align: center;
    flex: 1; min-width: 100px;
    transition: all 0.3s;
  }
  .credit-node:hover { border-color: var(--primary); background: rgba(0,212,255,0.05); }
  .credit-node-icon { font-size: 22px; margin-bottom: 6px; }
  .credit-node-label { font-size: 11px; font-weight: 600; color: var(--text2); }
  .credit-arrow { font-size: 18px; color: var(--primary); opacity: 0.5; flex-shrink: 0; }

  .benefit-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 10px; }
  .benefit-item {
    display: flex; align-items: flex-start; gap: 10px;
    background: var(--bg2); border-radius: 8px; padding: 12px;
    border: 1px solid transparent; transition: border-color 0.2s;
  }
  .benefit-item:hover { border-color: var(--border); }
  .benefit-icon { font-size: 18px; flex-shrink: 0; }
  .benefit-text { font-size: 12px; line-height: 1.5; color: var(--text2); }
  .benefit-text strong { color: var(--text); display: block; margin-bottom: 2px; }

  /* INSIGHT CARDS */
  .insight-card {
    background: var(--card2); border: 1px solid var(--border);
    border-radius: 10px; padding: 16px;
    border-left: 3px solid var(--primary);
    transition: transform 0.2s;
  }
  .insight-card:hover { transform: translateX(4px); }
  .insight-card.accent { border-left-color: var(--accent); }
  .insight-card.success { border-left-color: var(--success); }
  .insight-card.warning { border-left-color: var(--warning); }
  .insight-label { font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; color: var(--primary); margin-bottom: 6px; }
  .insight-card.accent .insight-label { color: var(--accent); }
  .insight-card.success .insight-label { color: var(--success); }
  .insight-card.warning .insight-label { color: var(--warning); }
  .insight-text { font-size: 13px; line-height: 1.6; color: var(--text2); }
  .insight-text strong { color: var(--text); }

  /* CEO PANEL */
  .ceo-grid { display: grid; grid-template-columns: repeat(5,1fr); gap: 12px; }
  .ceo-col {
    background: var(--card2); border: 1px solid var(--border);
    border-radius: 10px; padding: 16px;
  }
  .ceo-col-title {
    font-size: 11px; font-weight: 700; text-transform: uppercase;
    letter-spacing: 1px; margin-bottom: 12px; padding-bottom: 8px;
    border-bottom: 1px solid var(--border);
  }
  .ceo-col.opp .ceo-col-title { color: var(--success); }
  .ceo-col.risk .ceo-col-title { color: var(--danger); }
  .ceo-col.policy .ceo-col-title { color: var(--accent); }
  .ceo-col.credit .ceo-col-title { color: var(--primary); }
  .ceo-col.growth .ceo-col-title { color: var(--warning); }
  .ceo-item { font-size: 12px; color: var(--text2); line-height: 1.5; padding: 6px 0; border-bottom: 1px solid rgba(255,255,255,0.04); }
  .ceo-item:last-child { border-bottom: none; }
  .ceo-item::before { content: '→ '; color: inherit; opacity: 0.5; }

  /* STAT PILLS */
  .stat-row { display: flex; gap: 8px; flex-wrap: wrap; margin-top: 12px; }
  .stat-pill {
    background: var(--bg2); border: 1px solid var(--border);
    border-radius: 6px; padding: 6px 12px;
    font-size: 12px; display: flex; align-items: center; gap: 6px;
  }
  .stat-pill-label { color: var(--text3); }
  .stat-pill-value { color: var(--text); font-weight: 600; font-family: 'JetBrains Mono', monospace; }

  /* GENDER GAUGE */
  .gender-row { display: flex; gap: 8px; margin-bottom: 12px; }
  .gender-bar-wrap { flex: 1; }
  .gender-label { font-size: 12px; font-weight: 600; margin-bottom: 6px; display: flex; justify-content: space-between; }
  .gender-bar-bg { height: 12px; border-radius: 6px; background: rgba(255,255,255,0.06); overflow: hidden; }
  .gender-bar-fill { height: 100%; border-radius: 6px; transition: width 1s ease; }

  /* ZED PROGRESS */
  .zed-item { margin-bottom: 16px; }
  .zed-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 6px; }
  .zed-label { font-size: 13px; font-weight: 600; }
  .zed-val { font-size: 13px; font-family: 'JetBrains Mono', monospace; color: var(--text2); }
  .zed-track { height: 8px; border-radius: 4px; background: rgba(255,255,255,0.05); overflow: hidden; }
  .zed-fill { height: 100%; border-radius: 4px; transition: width 1.2s ease; }

  /* ANIMATIONS */
  @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.4} }
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes countUp { from { opacity:0 } to { opacity:1 } }
  @keyframes shimmer {
    0% { background-position: -200% center; }
    100% { background-position: 200% center; }
  }
  @keyframes glow-pulse {
    0%,100% { box-shadow: 0 0 20px rgba(0,212,255,0.1); }
    50% { box-shadow: 0 0 40px rgba(0,212,255,0.2); }
  }

  .section { animation: fadeUp 0.6s ease both; }
  .section:nth-child(2) { animation-delay: 0.1s; }
  .section:nth-child(3) { animation-delay: 0.2s; }

  /* HERO STRIP */
  .hero-strip {
    background: linear-gradient(135deg, rgba(0,212,255,0.08) 0%, rgba(123,97,255,0.08) 100%);
    border: 1px solid rgba(0,212,255,0.15);
    border-radius: 14px; padding: 28px 32px; margin-bottom: 36px;
    display: flex; align-items: center; justify-content: space-between;
    position: relative; overflow: hidden;
    animation: glow-pulse 4s ease infinite;
  }
  .hero-strip::after {
    content: ''; position: absolute; inset: 0;
    background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%2300D4FF' fill-opacity='0.02'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
    pointer-events: none;
  }
  .hero-title { font-size: 28px; font-weight: 900; letter-spacing: -1px; }
  .hero-title span { 
    background: linear-gradient(135deg, var(--primary), var(--accent));
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
  }
  .hero-sub { font-size: 13px; color: var(--text2); margin-top: 6px; max-width: 500px; }
  .hero-meta { text-align: right; }
  .hero-meta-val { font-size: 36px; font-weight: 900; color: var(--primary); font-family: 'JetBrains Mono', monospace; }
  .hero-meta-label { font-size: 11px; color: var(--text3); text-transform: uppercase; letter-spacing: 1px; }

  /* TOOLTIP */
  .tooltip-wrapper { position: relative; display: inline-block; }
  .tooltip-text {
    visibility: hidden; background: var(--card2); color: var(--text);
    font-size: 11px; border-radius: 6px; padding: 6px 10px;
    position: absolute; z-index: 100; bottom: 125%; left: 50%; transform: translateX(-50%);
    white-space: nowrap; border: 1px solid var(--border);
    opacity: 0; transition: opacity 0.2s;
  }
  .tooltip-wrapper:hover .tooltip-text { visibility: visible; opacity: 1; }

  /* India MAP */
  #indiaMapSvg { width: 100%; height: 400px; }
  .state-path {
    cursor: pointer; transition: opacity 0.2s;
    stroke: rgba(0,212,255,0.15); stroke-width: 0.5;
  }
  .state-path:hover { opacity: 0.7; stroke: var(--primary); stroke-width: 1.5; }

  /* SCORECARD */
  .scorecard {
    background: var(--bg2); border: 1px solid var(--border);
    border-radius: 10px; padding: 14px 16px;
    display: flex; align-items: center; gap: 12px;
  }
  .scorecard-icon { font-size: 24px; }
  .scorecard-label { font-size: 11px; color: var(--text3); margin-bottom: 2px; }
  .scorecard-val { font-size: 20px; font-weight: 800; font-family: 'JetBrains Mono', monospace; }

  /* RESPONSIVE */
  @media (max-width: 1200px) {
    .grid-6 { grid-template-columns: repeat(3,1fr); }
    .ceo-grid { grid-template-columns: repeat(3,1fr); }
  }
  @media (max-width: 900px) {
    .grid-4 { grid-template-columns: repeat(2,1fr); }
    .grid-3 { grid-template-columns: repeat(2,1fr); }
    .grid-1-2, .grid-2-1 { grid-template-columns: 1fr; }
    .benefit-grid { grid-template-columns: repeat(2,1fr); }
    .ceo-grid { grid-template-columns: repeat(2,1fr); }
    .sidebar { display: none; }
    .main { margin-left: 0; }
    .map-container { flex-direction: column; }
    .map-legend { width: 100%; }
  }
  @media (max-width: 600px) {
    .grid-6, .grid-4, .grid-3 { grid-template-columns: repeat(2,1fr); }
    .grid-2 { grid-template-columns: 1fr; }
    .hero-strip { flex-direction: column; gap: 16px; }
    .hero-meta { text-align: left; }
    .credit-flow { flex-direction: column; }
    .ceo-grid { grid-template-columns: 1fr; }
  }
  .span-2 { grid-column: span 2; }
  .span-3 { grid-column: span 3; }
</style>
</head>
